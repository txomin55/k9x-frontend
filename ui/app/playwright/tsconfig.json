{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "isolatedModules": true,
    "baseUrl": "..",
    "paths": {
      "@test/*": ["./playwright/*"]
    }
  },
  "include": ["./**/*.ts", "../src/**/*.spec.ts", "../src/**/*.spec.tsx"]
}
