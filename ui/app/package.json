{
  "name": "app",
  "type": "module",
  "scripts": {
    "build:sw": "vite build --config vite.sw.config.ts --mode ${CI_BUILD_ENV:-standalone}",
    "build:sw:develop": "vite build --config vite.sw.config.ts --mode standalone",
    "dev": "pnpm run start:integrated",
    "start:integrated": "pnpm run build:sw:develop && vite dev --mode integrated",
    "start:standalone": "pnpm run build:sw:develop && vite dev --mode standalone",
    "build": "pnpm run build:sw && vite build --mode ${CI_BUILD_ENV:-standalone} && node ./scripts/prefix-build-paths.mjs",
    "preview": "npx serve .output/public -l 5173",
    "test:unit:coverage": "vitest --coverage",
    "test:e2e:coverage": "playwright test"
  },
  "license": "MIT",
  "devDependencies": {
    "@bdellegrazie/playwright-sonar-reporter": "^0.4.0",
    "@playwright/test": "^1.58.2",
    "@solidjs/testing-library": "catalog:",
    "@solidjs/vite-plugin-nitro-2": "^0.1.0",
    "@stoplight/prism-cli": "^5.14.2",
    "@tanstack/router-plugin": "^1.167.4",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "monocart-coverage-reports": "^2.12.9",
    "my-vitest": "workspace:^",
    "vite": "catalog:",
    "vite-jsconfig-paths": "catalog:",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-solid": "catalog:",
    "vite-plugin-static-copy": "^3.1.4",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@solidjs/meta": "^0.29.4",
    "@solidjs/start": "2.0.0-alpha.2",
    "@tanstack/solid-query": "^5.91.1",
    "@tanstack/solid-router": "^1.167.4",
    "@tanstack/solid-store": "^0.9.2",
    "@tanstack/store": "^0.9.2",
    "dexie": "^4.3.0",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "js-yaml": "^4.1.1",
    "library": "workspace:^",
    "solid-js": "catalog:"
  }
}
