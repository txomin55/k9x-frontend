{
  "name": "app",
  "type": "module",
  "scripts": {
    "build:sw": "vite build --config vite.sw.config.ts --mode ${CI_BUILD_ENV:-production}",
    "build:sw:develop": "vite build --config vite.sw.config.ts --mode offline",
    "dev": "pnpm run start:integrated",
    "start:integrated": "pnpm run build:sw:develop && vite dev --mode integrated",
    "start:offline": "pnpm run build:sw:develop && pnpm run prepare:offline-oas && pnpm run start:offline:prepared",
    "start:offline:prepared": "test -f ./static/openapi.yaml && (pnpm run mock-server & vite dev --mode offline)",
    "build": "pnpm run build:sw && vite build --mode ${CI_BUILD_ENV:-production} && node ./scripts/prefix-build-paths.mjs",
    "serve": "vite start",
    "preview": "vite preview",
    "test:unit:coverage": "vitest --coverage",
    "test:e2e:coverage": "playwright test",
    "prepare:offline-oas": "mkdir -p ./static && curl --fail --location --retry 3 --retry-all-errors --connect-timeout 10 --max-time 60 https://cdn.jsdelivr.net/gh/txomin55/k9x-oas-definition@main/openapi.yaml -o ./static/openapi.yaml",
    "mock-server": "prism mock -d ./static/openapi.yaml"
  },
  "license": "MIT",
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@playwright/test": "^1.58.2",
    "@solidjs/router": "^0.15.3",
    "@solidjs/testing-library": "^0.8.10",
    "@solidjs/vite-plugin-nitro-2": "^0.1.0",
    "@stoplight/prism-cli": "^5.14.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitest/coverage-v8": "^4.0.15",
    "crypto-browserify": "^3.12.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "my-vitest": "workspace:^",
    "nyc": "^17.1.0",
    "require-context": "^1.1.0",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "stream-browserify": "^3.0.0",
    "vite-jsconfig-paths": "^2.0.1",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-plugin-environment": "^1.1.3",
    "vite-plugin-require-transform": "^1.0.21",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.15",
    "monocart-coverage-reports": "^2.12.9",
    "@bdellegrazie/playwright-sonar-reporter": "^0.4.0"
  },
  "dependencies": {
    "@solidjs/meta": "^0.29.4",
    "@solidjs/start": "2.0.0-alpha.2",
    "axios": "1.13.6",
    "i18next": "^24.2.3",
    "js-yaml": "^4.1.1",
    "library": "workspace:^",
    "openapi-client-axios": "7.9.0",
    "solid-js": "^1.9.10",
    "vite-plugin-static-copy": "^3.1.4"
  }
}
