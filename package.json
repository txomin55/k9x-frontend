{
  "name": "k9x-frontend",
  "private": true,
  "type": "module",
  "workspaces": [
    "ui/*",
    "configuration/*",
    "coverage_processor/*"
  ],
  "scripts": {
    "build": "turbo run build -- --mode ${CI_BUILD_ENV:-production}",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{cjs,js,jsx,ts,tsx,md,mdx}\"",
    "typecheck": "pnpm --filter ./ui/app exec tsc --noEmit -p tsconfig.json && pnpm --filter ./ui/app exec tsc --noEmit -p playwright/tsconfig.json && pnpm --filter ./ui/library exec tsc --noEmit -p tsconfig.json && pnpm --filter ./configuration/my-vitest exec tsc --noEmit -p tsconfig.json && pnpm --filter ./coverage_processor exec tsc --noEmit -p tsconfig.json",
    "test:unit:coverage": "turbo run test:unit:coverage --concurrency=1",
    "unit:coverage-merge": "tsx coverage_processor/unit_coverage_processor.ts",
    "unit:junit-merge": "tsx coverage_processor/unit_jUnit_processor.ts",
    "test:e2e:coverage": "pnpm --filter ./ui/app test:e2e:coverage",
    "total:coverage-merge": "tsx coverage_processor/total_coverage_processor.ts",
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter ./ui/app dev"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "jsdom": "27.2.0",
    "junit-report-merger": "^9.0.3",
    "prettier": "3.7.4",
    "regenerator-runtime": "^0.14.1",
    "tsx": "^4.20.6",
    "turbo": "^2.8.10",
    "typescript": "^5.4.5",
    "vite": "7.2.6",
    "vite-plugin-eslint": "^1.8.1",
    "vitest": "^4.0.15",
    "vitest-sonar-reporter": "^3.0.0"
  },
  "packageManager": "pnpm@10.30.0"
}
